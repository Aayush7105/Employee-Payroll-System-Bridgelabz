<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Employee Payroll Dashboard</title>
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <%
      const employeeCount = employees.length;
      const totalBasic = employees.reduce((sum, emp) => sum + Number(emp.salary || 0), 0);
      const totalTax = employees.reduce((sum, emp) => sum + Number(emp.salary || 0) * 0.12, 0);
      const totalNet = totalBasic - totalTax;
      const averageSalary = employeeCount ? totalBasic / employeeCount : 0;
      const formatINR = (amount) =>
        Number(amount || 0).toLocaleString("en-IN", {
          minimumFractionDigits: 2,
          maximumFractionDigits: 2
        });
    %>

    <header class="topbar">
      <div class="topbar-inner">
        <div>
          <h1 class="brand-title">Employee Payroll Dashboard</h1>
          <p class="brand-subtitle">
            Track salaries, taxes, and department performance in one place.
          </p>
        </div>
      </div>
    </header>

    <main class="page-shell">
      <section class="hero-panel">
        <div class="hero-copy">
          <p class="kicker">Payroll Center</p>
          <h2 class="hero-title">Compensation overview for your team</h2>
          <p>
            Review employee records, keep salary data up to date, and manage
            edits quickly from a single dashboard.
          </p>
        </div>
        <div class="hero-actions">
          <button
            class="btn-add"
            type="button"
            onclick="window.location.href='/add'"
          >
            + Add Employee
          </button>
        </div>
      </section>

      <section class="stats-grid">
        <article class="metric-card">
          <div class="metric-icon">
            <img src="/icons/emp.svg" alt="" />
          </div>
          <div>
            <p class="metric-label">Total Employees</p>
            <p class="metric-value"><%= employeeCount %></p>
          </div>
        </article>

        <article class="metric-card">
          <div class="metric-icon">
            <img src="/icons/basic.svg" alt="" />
          </div>
          <div>
            <p class="metric-label">Total Basic Salary</p>
            <p class="metric-value">&#8377;<%= formatINR(totalBasic) %></p>
          </div>
        </article>

        <article class="metric-card">
          <div class="metric-icon">
            <img src="/icons/tax.svg" alt="" />
          </div>
          <div>
            <p class="metric-label">Total Tax</p>
            <p class="metric-value">&#8377;<%= formatINR(totalTax) %></p>
          </div>
        </article>

        <article class="metric-card">
          <div class="metric-icon">
            <img src="/icons/net.svg" alt="" />
          </div>
          <div>
            <p class="metric-label">Total Net Salary</p>
            <p class="metric-value">&#8377;<%= formatINR(totalNet) %></p>
          </div>
        </article>

        <article class="metric-card">
          <div class="metric-icon">
            <img src="/icons/avg.svg" alt="" />
          </div>
          <div>
            <p class="metric-label">Average Salary</p>
            <p class="metric-value">&#8377;<%= formatINR(averageSalary) %></p>
          </div>
        </article>
      </section>

      <section class="table-panel">
        <div class="table-head">
          <h2>Employee Records</h2>
          <p><%= employeeCount %> employees listed</p>
        </div>

        <% if (employeeCount > 0) { %>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>ID</th>
                <th>Name</th>
                <th>DOB</th>
                <th>Position</th>
                <th>Department</th>
                <th>Basic Salary</th>
                <th>Tax (12%)</th>
                <th>Net Salary</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% employees.forEach((employee) => { %>
              <%
                const salary = Number(employee.salary || 0);
                const tax = salary * 0.12;
                const netSalary = salary - tax;
                const departments = Array.isArray(employee.department)
                  ? employee.department
                  : [employee.department];
              %>
              <tr>
                <td><%= employee.id %></td>
                <td><%= employee.name %></td>
                <td><%= employee.dob || "-" %></td>
                <td><%= employee.position %></td>
                <td>
                  <div class="dept-list">
                    <% departments.forEach((dept) => { %>
                    <span class="dept-pill"><%= dept %></span>
                    <% }) %>
                  </div>
                </td>
                <td class="amount">&#8377;<%= formatINR(salary) %></td>
                <td class="amount">&#8377;<%= formatINR(tax) %></td>
                <td class="amount">&#8377;<%= formatINR(netSalary) %></td>
                <td>
                  <div class="btn-main">
                    <a
                      class="btn-edit"
                      href="/edit/<%= employee.id %>"
                      aria-label="Edit employee <%= employee.id %>"
                    >
                      <img src="/icons/edit.svg" alt="" />
                    </a>
                    <button
                      class="btn-delete"
                      type="button"
                      onclick="deleteEmployee('<%= employee.id %>')"
                      aria-label="Delete employee <%= employee.id %>"
                    >
                      <img src="/icons/delete.svg" alt="" />
                    </button>
                  </div>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } else { %>
        <div class="empty-state">
          <p>
            No employees added yet.
            <a href="/add">Create the first employee</a> to start tracking
            payroll.
          </p>
        </div>
        <% } %>
      </section>
    </main>

    <script>
      function deleteEmployee(id) {
        if (confirm("Are you sure you want to delete this employee?")) {
          fetch(`/delete/${id}`, {
            method: "DELETE",
          })
            .then((response) => response.json())
            .then((data) => {
              alert(data.message);
              window.location.reload();
            })
            .catch((error) => {
              console.error("Error:", error);
              alert("Failed to delete employee");
            });
        }
      }
    </script>
  </body>
</html>
